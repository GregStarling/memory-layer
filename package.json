{
  "name": "memory-layer",
  "version": "2.0.0",
  "description": "Backend-agnostic memory package with scoped conversation history, compaction policy, orchestration workflows, and a SQLite adapter.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/gstarling/memory-layer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gstarling/memory-layer.git"
  },
  "bugs": {
    "url": "https://github.com/gstarling/memory-layer/issues"
  },
  "bin": {
    "memory-layer": "./bin/memory-server.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./summarizers/claude": {
      "import": "./dist/summarizers/claude.js",
      "types": "./dist/summarizers/claude.d.ts"
    },
    "./summarizers/openai": {
      "import": "./dist/summarizers/openai.js",
      "types": "./dist/summarizers/openai.d.ts"
    },
    "./summarizers/prompts": {
      "import": "./dist/summarizers/prompts.js",
      "types": "./dist/summarizers/prompts.d.ts"
    },
    "./summarizers/extractor": {
      "import": "./dist/summarizers/extractor.js",
      "types": "./dist/summarizers/extractor.d.ts"
    },
    "./embeddings/openai": {
      "import": "./dist/embeddings/openai.js",
      "types": "./dist/embeddings/openai.d.ts"
    },
    "./embeddings/voyage": {
      "import": "./dist/embeddings/voyage.js",
      "types": "./dist/embeddings/voyage.d.ts"
    },
    "./embeddings/local": {
      "import": "./dist/embeddings/local.js",
      "types": "./dist/embeddings/local.d.ts"
    },
    "./embeddings/resilience": {
      "import": "./dist/embeddings/resilience.js",
      "types": "./dist/embeddings/resilience.d.ts"
    },
    "./adapters/postgres": {
      "import": "./dist/adapters/postgres/index.js",
      "types": "./dist/adapters/postgres/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./server/http": {
      "import": "./dist/server/http-server.js",
      "types": "./dist/server/http-server.d.ts"
    },
    "./server/mcp": {
      "import": "./dist/server/mcp-server.js",
      "types": "./dist/server/mcp-server.d.ts"
    },
    "./integrations/langchain": {
      "import": "./dist/integrations/langchain.js",
      "types": "./dist/integrations/langchain.d.ts"
    },
    "./integrations/vercel-ai": {
      "import": "./dist/integrations/vercel-ai.js",
      "types": "./dist/integrations/vercel-ai.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "benchmark:search": "npm run build && node benchmarks/search-benchmark.mjs",
    "benchmark:semantic": "npm run build && node benchmarks/semantic-benchmark.mjs",
    "benchmark:compaction": "npm run build && node benchmarks/compaction-benchmark.mjs",
    "eval:retrieval": "npm run build && node evals/retrieval-quality.mjs",
    "eval:retrieval:enforce": "npm run build && node evals/retrieval-quality.mjs --enforce",
    "eval:scenarios": "npm run build && node evals/scenario-evals.mjs",
    "eval:gate": "npm run build && node evals/scenario-evals.mjs --enforce",
    "eval:memory-quality": "npm run build && node evals/memory-quality/index.mjs",
    "eval:memory-quality:enforce": "npm run build && node evals/memory-quality/index.mjs --enforce",
    "eval:memory-quality:delta": "npm run build && node scripts/report-memory-quality-delta.mjs",
    "eval:memory-quality:delta:enforce": "npm run build && node scripts/report-memory-quality-delta.mjs --enforce",
    "eval:platform-quality": "npm run build && node evals/platform-quality/index.mjs",
    "eval:platform-quality:enforce": "npm run build && node evals/platform-quality/index.mjs --enforce",
    "python:check": "cd clients/python && python3 -m venv .venv && .venv/bin/pip install -e '.[dev]' && .venv/bin/python -m build && .venv/bin/ruff check . && .venv/bin/pytest",
    "export:memory": "node scripts/export-memory.mjs",
    "import:memory": "node scripts/import-memory.mjs",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run lint && npm run test:coverage && npm run eval:retrieval:enforce && npm run eval:gate && npm run eval:memory-quality:enforce && npm run eval:memory-quality:delta:enforce && npm run python:check && npm run eval:platform-quality:enforce && npm run pack:check",
    "prepublishOnly": "npm run release:check"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/__tests__/**",
    "bin",
    "docs",
    "openapi.yaml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "memory",
    "sqlite",
    "retrieval",
    "rag",
    "agent"
  ]
}
